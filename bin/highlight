#!/usr/bin/env bash
# highlight - pipe text through while colorizing matched words
# (Generated by Claude.)
#
# Usage: highlight [OPTIONS] PATTERN [PATTERN2 ...]
#        command | highlight [OPTIONS] PATTERN [PATTERN2 ...]
#
# Options:
#   -i          Case-insensitive matching
#   -w          Match whole words only
#   -f FILE     Read patterns from file (one per line)
#   -c COLOR    Color for next pattern: red green yellow blue magenta cyan white
#               or bold underline reverse  (prefix with capital for bright/bold)
#   --          End of options, treat rest as patterns
#   -h, --help  Show this help

set -euo pipefail

declare -A COLORS=(
    [red]=$'\033[0;31m'       [RED]=$'\033[1;31m'
    [green]=$'\033[0;32m'     [GREEN]=$'\033[1;32m'
    [yellow]=$'\033[0;33m'    [YELLOW]=$'\033[1;33m'
    [blue]=$'\033[0;34m'      [BLUE]=$'\033[1;34m'
    [magenta]=$'\033[0;35m'   [MAGENTA]=$'\033[1;35m'
    [cyan]=$'\033[0;36m'      [CYAN]=$'\033[1;36m'
    [white]=$'\033[0;37m'     [WHITE]=$'\033[1;37m'
    [bold]=$'\033[1m'
    [underline]=$'\033[4m'
    [reverse]=$'\033[7m'
)
RESET=$'\033[0m'
DEFAULT_COLORS=(RED GREEN YELLOW MAGENTA CYAN BLUE)

usage() {
    grep '^#' "$0" | sed 's/^# \{0,1\}//' | tail -n +2
    exit "${1:-0}"
}

die() { echo "highlight: $*" >&2; exit 1; }

patterns=()
pat_colors=()
case_flag=""
word_flag=""
next_color=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) usage 0 ;;
        -i) case_flag="I"; shift ;;
        -w) word_flag=1; shift ;;
        -f)
            [[ -n "${2-}" ]] || die "-f requires a filename"
            [[ -f "$2" ]] || die "file not found: $2"
            while IFS= read -r line || [[ -n "$line" ]]; do
                [[ -z "$line" || "$line" == \#* ]] && continue
                patterns+=("$line")
                pat_colors+=("")
            done < "$2"
            shift 2 ;;
        -c)
            [[ -n "${2-}" ]] || die "-c requires a color name"
            key="${2^^}"
            [[ -v "COLORS[$key]" ]] || \
                die "unknown color '$2'. Valid: red RED green GREEN yellow YELLOW blue BLUE magenta MAGENTA cyan CYAN white WHITE bold underline reverse"
            next_color="$key"
            shift 2 ;;
        --) shift; break ;;
        -*)  die "unknown option: $1 (try --help)" ;;
        *)
            patterns+=("$1")
            pat_colors+=("$next_color")
            next_color=""
            shift ;;
    esac
done

# Remaining args after --
while [[ $# -gt 0 ]]; do
    patterns+=("$1")
    pat_colors+=("$next_color")
    next_color=""
    shift
done

[[ ${#patterns[@]} -gt 0 ]] || { usage 1; }

# Build sed -e args

sed_args=()
for i in "${!patterns[@]}"; do
    pat="${patterns[$i]}"
    col="${pat_colors[$i]:-}"
    [[ -z "$col" ]] && col="${DEFAULT_COLORS[$((i % ${#DEFAULT_COLORS[@]}))]}"

    ansi="${COLORS[$col]}"

    # Escape for sed replacement string
    esc_color=$(printf '%s' "$ansi" | sed 's/[\/&]/\\&/g')
    esc_reset=$(printf '%s' "$RESET" | sed 's/[\/&]/\\&/g')

    full_pat="$pat"
    [[ -n "$word_flag" ]] && full_pat='\b'"$pat"'\b'

    sed_args+=(-e "s/${full_pat}/${esc_color}&${esc_reset}/g${case_flag}")
done

exec sed "${sed_args[@]}"
