#!/usr/bin/env bash
# clipboard paste, ported from the pbpaste alias in .zsh.d/50-aliases-system.zsh.
# When SSH'd in and inside tmux, print tmux's buffer instead, since there's no
# X clipboard to target over SSH.
set -euo pipefail

if [[ -n "${SSH_CONNECTION:-}" && -n "${TMUX:-}" ]]; then
  exec tmux save-buffer -
else
  exec xclip -sel clip -o
fi
